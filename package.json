{
  "name": "mixi",
  "version": "0.3.3",
  "author": "Fabrizio Salmi <fabrizio.salmi@gmail.com>",
  "description": "Deterministic Audio Workstation",
  "homepage": "https://github.com/fabriziosalmi/mixi",
  "repository": {
    "type": "git",
    "url": "https://github.com/fabriziosalmi/mixi.git"
  },
  "private": true,
  "type": "module",
  "main": "electron/dist/main.cjs",
  "scripts": {
    "dev": "concurrently -c \"cyan,magenta,yellow\" -n \"UI,API,MCP\" \"npm run dev:ui\" \"npm run dev:api\" \"npm run dev:mcp\"",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "dev:ui": "vite",
    "dev:api": "cd api && uvicorn main:app --reload --port ${PORT:-8000}",
    "dev:mcp": "cd api && python mcp_server.py",
    "dev:electron": "npm run build:electron && concurrently -c \"cyan,magenta\" -n \"UI,ELECTRON\" \"vite\" \"electron .\"",
    "build:wasm": "cd mixi-core && RUSTFLAGS='-C target-feature=+simd128' wasm-pack build --target web --release --out-dir pkg",
    "build": "node -e \"if(!process.env.SKIP_WASM_BUILD){const{execSync}=require('child_process');execSync('npm run build:wasm',{stdio:'inherit'})}\" && tsc -b && vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"require('fs').renameSync('electron/dist/main.js', 'electron/dist/main.cjs'); require('fs').renameSync('electron/dist/preload.js', 'electron/dist/preload.cjs');\"",
    "build:all": "npm run build && npm run build:electron",
    "build:engine": "cd api && pyinstaller --onefile --name mixi-engine main.py",
    "dist": "npm run build:all && electron-builder",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:linux": "npm run build:all && electron-builder --linux",
    "preview": "vite preview"
  },
  "dependencies": {
    "music-metadata": "^11.12.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/webmidi": "^2.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.4.2",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.mixi.dj",
    "productName": "Mixi",
    "copyright": "Copyright © 2026 Fabrizio Salmi",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/dist/**/*",
      "electron/package.json",
      "skins/**/*"
    ],
    "extraResources": [
      {
        "from": "api/dist/mixi-engine${env.EXEC_EXT}",
        "to": "mixi-engine${env.EXEC_EXT}"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.music"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Audio"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
